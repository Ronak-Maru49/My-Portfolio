@{
    ViewData["Title"] = "FAQ - Frequently Asked Questions";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>
    :root {
        --primary-blue: #2563eb;
    }

    /* Isse section pure screen ki width lega */
    .full-width-faq {
        width: 100%;
        padding: 0;
        margin: 0;
        background-color: #f3f4f6; /* Light background color for full page */
        min-height: 100vh; /* Ensures background covers full height */
    }

    .faq-card {
        border-radius: 40px;
        overflow: hidden;
        border: none;
        background: #fff;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        margin-bottom: 4rem;
        /* Card ko center mein rakhne ke liye margins */
        margin-left: auto;
        margin-right: auto;
        max-width: 95%; /* Bilkul screen se na chipke isliye 95% rakha hai */
    }

    /* Left Side Styling */
    .faq-image-side {
        position: relative;
        min-height: 400px; /* Changed from 600px to 400px - choti height */
        overflow: hidden;
    }

        .faq-image-side img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .faq-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 40px; /* Reduced padding to match smaller height */
    }

        .faq-overlay h2 {
            color: white;
            font-weight: 800;
            font-size: 2.5rem; /* Slightly reduced font size */
            line-height: 1.1;
            margin-bottom: 15px;
        }

        .faq-overlay p {
            color: rgba(255,255,255,0.9);
            font-size: 1rem; /* Slightly reduced font size */
            max-width: 400px;
        }

    /* Right Side Content Styling */
    .faq-content-side {
        padding: 60px !important; /* Slightly reduced padding */
    }

    .content-header {
        font-weight: 800;
        font-size: 2rem; /* Slightly reduced font size */
        margin-bottom: 35px;
        color: #111827;
    }

    .sub-item-box {
        display: flex;
        gap: 20px; /* Slightly reduced gap */
        margin-bottom: 30px; /* Slightly reduced margin */
    }

    .icon-circle {
        width: 40px;
        height: 40px;
        background-color: var(--primary-blue);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .sub-text-content h5 {
        font-weight: 700;
        font-size: 1.1rem; /* Slightly reduced font size */
        margin-bottom: 8px;
        color: #111827;
    }

    .sub-text-content p {
        color: #6b7280;
        font-size: 0.95rem; /* Slightly reduced font size */
        line-height: 1.6;
        margin: 0;
    }

    .btn-read-more {
        background-color: var(--primary-blue);
        color: white;
        padding: 12px 35px; /* Slightly reduced padding */
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        float: right;
        transition: all 0.3s ease;
    }

        .btn-read-more:hover {
            background-color: #1d4ed8;
            color: white;
        }

    .sub-item-box:not(:last-of-type) {
        border-bottom: 1px solid #f3f4f6;
        padding-bottom: 25px;
    }

    /* Mobile Responsive adjustment */
    @@media (max-width: 768px) {
        .faq-image-side {
            min-height: 250px; /* Further reduced for mobile */
        }

        .faq-content-side {
            padding: 30px !important;
        }

        .faq-overlay h2 {
            font-size: 1.8rem;
        }

        .faq-overlay {
            padding: 25px;
        }
    }
</style>

<section class="py-5 full-width-faq">
    <div class="container-fluid" id="faqSections">
    </div>
</section>

<script>
    const CAT_API = 'https://localhost:7032/api/FaqCategory';
    const SUBCAT_API = 'https://localhost:7032/api/FaqSubCategory';

    function esc(str) {
        if (str == null) return '';
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function getSubCategoriesHtml(categoryId, allSubCats) {
        const filtered = allSubCats.filter(s => s.categoryId === categoryId);
        if (filtered.length === 0) return '<p class="text-muted">No topics available.</p>';

        return filtered.slice(0, 4).map((s, index) => `
            <div class="sub-item-box">
                <div class="icon-circle">${index + 1}</div>
                <div class="sub-text-content">
                    <h5>${esc(s.subCategoryName)}</h5>
                    <p>${esc(s.subCategoryDescription || '')}</p>
                </div>
            </div>
        `).join('');
    }

    function buildSectionHtml(cat, allSubCats) {
        const imageUrl = cat.categoryImage || 'https://images.unsplash.com/photo-1677442136019-21780ecad995';
        const subHtml = getSubCategoriesHtml(cat.id, allSubCats);

        return `
        <div class="faq-card shadow">
            <div class="row g-0">
                <div class="col-md-5 faq-image-side">
                    <img src="${imageUrl}" />
                    <div class="faq-overlay">
                        <h2>${esc(cat.categoryName)}</h2>
                        <p>${esc(cat.categoryDescription || '')}</p>
                    </div>
                </div>
                <div class="col-md-7 faq-content-side">
                    <h3 class="content-header">${esc(cat.categoryName)} FAQ</h3>

                    <div class="sub-list-wrapper">
                        ${subHtml}
                    </div>

                     <div class="mt-4 overflow-hidden">
        <a asp-controller="FAQ" asp-action="Details" asp-route-catId="${cat.id}" class="btn-read-more" target="_blank" rel="noopener noreferrer">
            Read More <i class="bi bi-arrow-right"></i>
        </a>
    </div>
                </div>
            </div>
        </div>`;
    }

    async function loadFaqData() {
        const container = document.getElementById('faqSections');
        try {
            const [catRes, subRes] = await Promise.all([fetch(CAT_API), fetch(SUBCAT_API)]);
            const categories = await catRes.json();
            const subCategories = await subRes.json();

            container.innerHTML = categories.map(cat => buildSectionHtml(cat, subCategories)).join('');
        } catch (err) {
            container.innerHTML = `<div class="text-center py-5 text-danger">Error loading data.</div>`;
        }
    }

    loadFaqData();
</script>