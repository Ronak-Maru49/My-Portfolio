@{
    ViewData["Title"] = "FAQ - Frequently Asked Questions";
}
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />

    <style>
        :root {
            --bg-primary: #080c10;
            --bg-card: #0e1419;
            --bg-card-hover: #131a22;
            --accent: #00e5a0;
            --accent-dim: rgba(0,229,160,0.12);
            --accent-border: rgba(0,229,160,0.25);
            --text-primary: #eef2f7;
            --text-secondary: #8a9bb0;
            --text-muted: #4d5f72;
            --border: rgba(255,255,255,0.06);
            --border-hover: rgba(0,229,160,0.3);
            --shadow-card: 0 2px 24px rgba(0,0,0,0.45);
            --shadow-hover: 0 8px 40px rgba(0,229,160,0.08);
            --font-display: 'Syne', sans-serif;
            --font-body: 'DM Sans', sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            font-family: var(--font-body);
            font-size: 16px;
            line-height: 1.7;
            min-height: 100vh;
        }

            /* Grain overlay */
            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
                pointer-events: none;
                z-index: 0;
                opacity: 0.35;
            }
        /* ── Hero ── */
        .faq-hero {
            padding: 5rem 0 4rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

            .faq-hero::after {
                content: '';
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -65%);
                width: 700px;
                height: 700px;
                background: radial-gradient(circle, rgba(0,229,160,0.07) 0%, transparent 68%);
                pointer-events: none;
            }

        .hero-label {
            display: inline-block;
            background: var(--accent-dim);
            border: 1px solid var(--accent-border);
            color: var(--accent);
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            border-radius: 100px;
            padding: 0.32rem 1rem;
            margin-bottom: 1.4rem;
        }

        .faq-hero h1 {
            font-family: var(--font-display);
            font-weight: 800;
            font-size: clamp(2rem, 5vw, 3.5rem);
            line-height: 1.08;
            letter-spacing: -1.5px;
            color: var(--text-primary);
            margin-bottom: 1rem;
        }

        .faq-hero p {
            color: var(--text-secondary);
            font-size: 1.05rem;
            max-width: 520px;
            margin: 0 auto;
            font-weight: 300;
        }

        /* ── Category Tab Pills ── */
        .category-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
            margin-top: 2.5rem;
            position: relative;
            z-index: 2;
        }

        .cat-pill {
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 0.8rem;
            font-weight: 500;
            border-radius: 100px;
            padding: 0.38rem 1rem;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

            .cat-pill:hover, .cat-pill.active {
                background: var(--accent-dim);
                border-color: var(--accent-border);
                color: var(--accent);
            }

        /* ── Admin Toggle Bar ── */
        .admin-toggle-bar {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 1.5rem;
            position: relative;
            z-index: 1;
        }

        .btn-admin-toggle {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.8rem;
            font-weight: 500;
            border-radius: 6px;
            padding: 0.4rem 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

            .btn-admin-toggle:hover {
                border-color: var(--accent-border);
                color: var(--accent);
            }

        /* ── Admin Panel ── */
        .admin-panel {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.8rem;
            margin-bottom: 3rem;
            position: relative;
            z-index: 1;
            display: none;
        }

            .admin-panel.show {
                display: block;
                animation: slideDown 0.25s ease;
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .admin-panel-title {
            font-family: var(--font-display);
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 1.4rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .admin-panel-title i {
                color: var(--accent);
            }

        .form-label {
            color: var(--text-secondary);
            font-size: 0.82rem;
            font-weight: 500;
            margin-bottom: 0.35rem;
        }

        .form-control, .form-select {
            background: #0a0f15;
            border: 1px solid var(--border);
            color: var(--text-primary);
            border-radius: 8px;
            font-size: 0.875rem;
            padding: 0.55rem 0.9rem;
            transition: border-color 0.2s;
        }

            .form-control:focus, .form-select:focus {
                background: #0a0f15;
                border-color: var(--accent-border);
                box-shadow: 0 0 0 3px rgba(0,229,160,0.08);
                color: var(--text-primary);
            }

            .form-control::placeholder {
                color: var(--text-muted);
            }

            .form-select option {
                background: #0e1419;
            }

        .btn-create {
            background: var(--accent);
            color: #080c10;
            font-weight: 700;
            font-size: 0.85rem;
            border: none;
            border-radius: 8px;
            padding: 0.55rem 1.3rem;
            transition: opacity 0.2s, transform 0.2s;
            cursor: pointer;
        }

            .btn-create:hover {
                opacity: 0.85;
                transform: translateY(-1px);
            }

        .btn-update {
            background: transparent;
            color: var(--accent);
            font-weight: 600;
            font-size: 0.85rem;
            border: 1px solid var(--accent-border);
            border-radius: 8px;
            padding: 0.55rem 1.3rem;
            transition: all 0.2s;
            cursor: pointer;
        }

            .btn-update:hover {
                background: var(--accent-dim);
            }

        .btn-cancel-edit {
            background: transparent;
            color: var(--text-muted);
            font-size: 0.82rem;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.55rem 1rem;
            cursor: pointer;
            transition: all 0.2s;
        }

            .btn-cancel-edit:hover {
                color: var(--text-secondary);
            }

        /* ── Admin Table ── */
        .admin-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 0.4rem;
            font-size: 0.83rem;
            margin-top: 1.2rem;
        }

            .admin-table thead th {
                color: var(--text-muted);
                font-size: 0.7rem;
                font-weight: 600;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                padding: 0.4rem 0.75rem;
                border-bottom: 1px solid var(--border);
            }

            .admin-table tbody tr {
                background: #0a0f15;
            }

            .admin-table tbody td {
                padding: 0.7rem 0.75rem;
                color: var(--text-secondary);
                border-top: 1px solid var(--border);
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

                .admin-table tbody td:first-child {
                    border-left: 1px solid var(--border);
                    border-radius: 8px 0 0 8px;
                }

                .admin-table tbody td:last-child {
                    border-right: 1px solid var(--border);
                    border-radius: 0 8px 8px 0;
                }

            .admin-table tbody tr:hover td {
                background: var(--bg-card-hover);
            }

        .td-name {
            color: var(--text-primary);
            font-weight: 500;
        }

        .td-seq {
            display: inline-block;
            background: var(--accent-dim);
            color: var(--accent);
            font-size: 0.72rem;
            font-weight: 700;
            border-radius: 4px;
            padding: 0.1rem 0.45rem;
        }

        .td-badge {
            display: inline-block;
            background: rgba(255,255,255,0.05);
            color: var(--text-muted);
            font-size: 0.72rem;
            border-radius: 4px;
            padding: 0.1rem 0.5rem;
        }

            .td-badge.yes {
                background: rgba(0,229,160,0.1);
                color: var(--accent);
            }

        .btn-tbl-edit, .btn-tbl-del {
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.25rem 0.6rem;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.18s;
        }

        .btn-tbl-edit {
            color: var(--accent);
        }

            .btn-tbl-edit:hover {
                background: var(--accent-dim);
                border-color: var(--accent-border);
            }

        .btn-tbl-del {
            color: #ff6b6b;
            margin-left: 0.3rem;
        }

            .btn-tbl-del:hover {
                background: rgba(255,107,107,0.1);
                border-color: rgba(255,107,107,0.3);
            }

        /* ── Public FAQ Sections ── */
        .faq-content-area {
            position: relative;
            z-index: 1;
            padding-bottom: 5rem;
        }

        .faq-section-block {
            padding: 2.5rem 0 1.5rem;
            border-bottom: 1px solid var(--border);
        }

            .faq-section-block:last-child {
                border-bottom: none;
            }

        .section-header {
            display: flex;
            align-items: flex-start;
            gap: 1.4rem;
            margin-bottom: 1.8rem;
        }

        .section-thumb {
            width: 80px;
            height: 80px;
            border-radius: 14px;
            object-fit: cover;
            border: 1px solid var(--border);
            flex-shrink: 0;
        }

        .section-thumb-placeholder {
            width: 80px;
            height: 80px;
            border-radius: 14px;
            border: 1px solid var(--border);
            flex-shrink: 0;
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            color: var(--text-muted);
        }

        .section-category-label {
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 0.25rem;
        }

        .section-title {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 1.4rem;
            color: var(--text-primary);
            line-height: 1.2;
            margin-bottom: 0.35rem;
        }

        .section-desc {
            color: var(--text-muted);
            font-size: 0.86rem;
            line-height: 1.6;
        }

        /* ── Accordion ── */
        .faq-accordion {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .faq-item {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .faq-item:hover {
                border-color: var(--border-hover);
                box-shadow: var(--shadow-hover);
            }

            .faq-item.open {
                border-color: var(--accent-border);
            }

        .faq-q {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.1rem 1.4rem;
            cursor: pointer;
            user-select: none;
        }

        .faq-num {
            flex-shrink: 0;
            width: 28px;
            height: 28px;
            background: rgba(0,229,160,0.08);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 0.72rem;
            font-weight: 700;
            color: var(--accent);
        }

        .faq-q-text {
            flex: 1;
            font-weight: 500;
            font-size: 0.95rem;
            color: var(--text-primary);
        }

        .faq-chevron {
            color: var(--text-muted);
            font-size: 1rem;
            transition: transform 0.25s;
            flex-shrink: 0;
        }

        .faq-item.open .faq-chevron {
            transform: rotate(180deg);
            color: var(--accent);
        }

        .faq-a {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, padding 0.25s ease;
            padding: 0 1.4rem 0 3.7rem;
        }

        .faq-item.open .faq-a {
            max-height: 300px;
            padding-bottom: 1.2rem;
        }

        .faq-a-text {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.75;
        }

        /* ── Skeleton ── */
        .skeleton {
            background: linear-gradient(90deg, var(--bg-card) 25%, #131a22 50%, var(--bg-card) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.4s infinite;
            border-radius: 8px;
        }

            100% {
                background-position: -200% 0;
            }
        }

        .skel-header {
            height: 80px;
            width: 100%;
            border-radius: 12px;
            margin-bottom: 1rem;
        }

        .skel-item {
            height: 56px;
            width: 100%;
            border-radius: 10px;
            margin-bottom: 0.5rem;
        }

        /* ── Empty / Error state ── */
        .empty-state {
            text-align: center;
            padding: 4rem 1rem;
            color: var(--text-muted);
        }

            .empty-state i {
                font-size: 2.5rem;
                margin-bottom: 1rem;
                display: block;
                color: var(--border);
            }

            .empty-state p {
                font-size: 0.9rem;
            }

            .empty-state code {
                background: var(--bg-card);
                border-radius: 4px;
                padding: 0.1rem 0.4rem;
                font-size: 0.82rem;
            }

        /* ── Toast ── */
        .toast-container {
            position: fixed;
            bottom: 1.5rem;
            right: 1.5rem;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .my-toast {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 0.85rem 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.7rem;
            font-size: 0.85rem;
            color: var(--text-primary);
            box-shadow: var(--shadow-card);
            animation: toastIn 0.3s ease;
            min-width: 240px;
        }

            .my-toast.success {
                border-left: 3px solid var(--accent);
            }

            .my-toast.error {
                border-left: 3px solid #ff6b6b;
            }

            .my-toast .ti-success {
                color: var(--accent);
            }

            .my-toast .ti-error {
                color: #ff6b6b;
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── Footer ── */
        .site-footer {
            background: var(--bg-card);
            border-top: 1px solid var(--border);
            padding: 3rem 0 2rem;
            position: relative;
            z-index: 1;
        }

        .footer-brand {
            font-family: var(--font-display);
            font-weight: 800;
            font-size: 1.3rem;
            color: var(--text-primary);
        }

            .footer-brand span {
                color: var(--accent);
            }

        .footer-tagline {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-top: 0.4rem;
        }

        .footer-heading {
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        .footer-link {
            display: block;
            color: var(--text-secondary);
            font-size: 0.87rem;
            text-decoration: none;
            margin-bottom: 0.45rem;
            transition: color 0.2s;
        }

            .footer-link:hover {
                color: var(--accent);
            }

        .footer-bottom {
            border-top: 1px solid var(--border);
            margin-top: 2rem;
            padding-top: 1.5rem;
            color: var(--text-muted);
            font-size: 0.8rem;
        }

        @@media (max-width: 576px) {
            .section-header {
                flex-direction: column;
            }

            .admin-table {
                font-size: 0.75rem;
            }
        }
    </style>
    <!-- ═══════════════════════ HERO ═══════════════════════ -->
    <section class="faq-hero">
        <div class="container">
            <span class="hero-label"><i class="bi bi-patch-question me-1"></i> Knowledge Base</span>
            <h1>Frequently Asked<br>Questions</h1>
            <p>Find quick answers to common questions about our services, process, pricing, and support.</p>
            <!-- Category filter pills (populated by JS) -->
            <div class="category-tabs" id="categoryTabs">
                <button class="cat-pill active" data-id="all">All Categories</button>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════ MAIN ═══════════════════════ -->
    <main class="container faq-content-area" style="padding-top:2.5rem;">

        <!-- Admin Panel Toggle -->
        <div class="admin-toggle-bar">
            <button class="btn-admin-toggle" id="btnToggleAdmin">
                <i class="bi bi-sliders2"></i> Manage Categories
            </button>
        </div>

        <!-- ── ADMIN CRUD PANEL ── -->
        <div class="admin-panel" id="adminPanel">
            <div class="admin-panel-title">
                <i class="bi bi-grid-3x3-gap-fill"></i>
                <span id="panelTitle">Add New Category</span>
            </div>

            <input type="hidden" id="editId" />

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Category Name <span style="color:#ff6b6b">*</span></label>
                    <input type="text" class="form-control" id="inputName" placeholder="e.g. AI MVP Development" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Image URL</label>
                    <input type="text" class="form-control" id="inputImage" placeholder="https://example.com/image.jpg" />
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" id="inputDesc" rows="2"
                              placeholder="Short description of this FAQ category..."></textarea>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Category Sequence</label>
                    <input type="number" class="form-control" id="inputSeq" placeholder="1" min="1" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Is Parent?</label>
                    <select class="form-select" id="inputIsParent">
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Parent Sequence</label>
                    <input type="number" class="form-control" id="inputParentSeq" placeholder="0" min="0" />
                </div>
            </div>

            <div class="d-flex gap-2 flex-wrap mb-4">
                <button class="btn-create" id="btnCreate" onclick="createCategory()">
                    <i class="bi bi-plus-circle me-1"></i> Create Category
                </button>
                <button class="btn-update d-none" id="btnUpdate" onclick="updateCategory()">
                    <i class="bi bi-check-circle me-1"></i> Save Changes
                </button>
                <button class="btn-cancel-edit d-none" id="btnCancel" onclick="cancelEdit()">
                    Cancel
                </button>
            </div>

            <!-- Existing categories table -->
            <div>
                <div style="color:var(--text-muted);font-size:0.82rem;margin-bottom:0.5rem;">Existing Categories</div>
                <div style="overflow-x:auto;">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Seq</th>
                                <th>Parent?</th>
                                <th>Parent Seq</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="adminTableBody">
                            <tr>
                                <td colspan="7" style="color:var(--text-muted);text-align:center;padding:1.2rem;">
                                    Loading...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ── PUBLIC FAQ VIEW ── -->
        <div id="faqPublicView">
            <!-- Skeleton loader -->
            <div id="faqSkeleton">
                <div class="mb-4">
                    <div class="skeleton skel-header"></div>
                    <div class="skeleton skel-item"></div>
                    <div class="skeleton skel-item"></div>
                    <div class="skeleton skel-item"></div>
                </div>
                <div class="mb-4">
                    <div class="skeleton skel-header"></div>
                    <div class="skeleton skel-item"></div>
                    <div class="skeleton skel-item"></div>
                </div>
            </div>
            <!-- Categories rendered here -->
            <div id="faqSections"></div>
        </div>

    </main>

    <!-- ═══════════════════════ FOOTER ═══════════════════════ -->
    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">My<span>.</span></div>
                    <p class="footer-tagline">Building scalable AI systems and custom software solutions.</p>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Services</div>
                    <a class="footer-link" href="#">Computer Vision</a>
                    <a class="footer-link" href="#">Generative AI</a>
                    <a class="footer-link" href="#">ML Development</a>
                    <a class="footer-link" href="#">Model Training</a>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Links</div>
                    <a class="footer-link" href="#">Home</a>
                    <a class="footer-link" href="#">Blog</a>
                    <a class="footer-link" href="#">Case Studies</a>
                    <a class="footer-link" href="#">FAQ's</a>
                </div>
                <div class="col-lg-4 col-md-6">
                    <div class="footer-heading">Contact</div>
                    <a class="footer-link" href="mailto:hello@example.com">
                        <i class="bi bi-envelope me-2"></i>hello@example.com
                    </a>
                    <a class="footer-link" href="tel:+919876543210">
                        <i class="bi bi-telephone me-2"></i>+91 98765 43210
                    </a>
                </div>
            </div>
            <div class="footer-bottom d-flex flex-wrap justify-content-between gap-2">
                <span>© 2026 MyBrand. All rights reserved.</span>
                <span>Built with <i class="bi bi-heart-fill" style="color:var(--accent);font-size:0.7rem;"></i> ASP.NET Core</span>
            </div>
        </div>
    </footer>

    <!-- Toast container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ══════════════════════════════════════════════════════════
        //  CONFIG
        //  Change this to your actual API base URL if needed.
        //  When the FAQ page is served from the same ASP.NET app
        //  as the controller, a relative path like '/api/FaqCategory'
        //  works out of the box.
        // ══════════════════════════════════════════════════════════
        const API_BASE = 'https://localhost:7032/api/FaqCategory';

        // ── App state ─────────────────────────────────────────────
        let allCategories = [];
        let activeFilter  = 'all';

        // ══════════════════════════════════════════════════════════
        //  API CALLS
        // ══════════════════════════════════════════════════════════

        // GET /api/FaqCategory  — load all categories
        async function fetchCategories() {
            try {
                const res = await fetch(API_BASE);

                if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);

                allCategories = await res.json();
                renderAll();

            } catch (err) {
                console.error('fetchCategories error:', err);
                showToast('Failed to load categories. Check API connection.', 'error');
                hideSkeleton();
                document.getElementById('faqSections').innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-wifi-off"></i>
                        <p>Could not reach the API at <code>${API_BASE}</code>.<br>
                           Make sure your API project is running.</p>
                    </div>`;
            }
        }

        // POST /api/FaqCategory  — create a new category
        async function createCategory() {
            const payload = buildPayload();
            if (!payload) return;

            try {
                const res = await fetch(API_BASE, {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify(payload)
                });

                if (!res.ok) throw new Error(`HTTP ${res.status}`);

                const json = await res.json();
                showToast(json.message || 'Category created successfully!', 'success');
                clearForm();
                await fetchCategories();   // refresh list

            } catch (err) {
                console.error('createCategory error:', err);
                showToast('Create failed: ' + err.message, 'error');
            }
        }

        // PUT /api/FaqCategory/{id}  — update existing category
        async function updateCategory() {
            const id = document.getElementById('editId').value;
            if (!id) return;

            const payload = buildPayload();
            if (!payload) return;

            try {
                const res = await fetch(`${API_BASE}/${id}`, {
                    method:  'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify(payload)
                });

                if (!res.ok) throw new Error(`HTTP ${res.status}`);

                const json = await res.json();
                showToast(json.message || 'Category updated successfully!', 'success');
                cancelEdit();
                await fetchCategories();   // refresh list

            } catch (err) {
                console.error('updateCategory error:', err);
                showToast('Update failed: ' + err.message, 'error');
            }
        }

        // DELETE /api/FaqCategory/{id}  — delete a category
        async function deleteCategory(id, name) {
            if (!confirm(`Are you sure you want to delete "${name}"?`)) return;

            try {
                const res = await fetch(`${API_BASE}/${id}`, { method: 'DELETE' });

                if (!res.ok) throw new Error(`HTTP ${res.status}`);

                const json = await res.json();
                showToast(json.message || 'Category deleted!', 'success');
                await fetchCategories();   // refresh list

            } catch (err) {
                console.error('deleteCategory error:', err);
                showToast('Delete failed: ' + err.message, 'error');
            }
        }

        // GET /api/FaqCategory/{id}  — load one category into the edit form
        async function editCategory(id) {
            try {
                const res = await fetch(`${API_BASE}/${id}`);
                if (!res.ok) throw new Error(`HTTP ${res.status}`);

                const cat = await res.json();

                // Populate form fields
                document.getElementById('editId').value         = cat.id;
                document.getElementById('inputName').value      = cat.categoryName        ?? '';
                document.getElementById('inputDesc').value      = cat.categoryDescription ?? '';
                document.getElementById('inputImage').value     = cat.categoryImage       ?? '';
                document.getElementById('inputSeq').value       = cat.categorySequence    ?? '';
                document.getElementById('inputIsParent').value  = cat.isParent ? 'true' : 'false';
                document.getElementById('inputParentSeq').value = cat.parentSequence      ?? '';

                // Switch form to "edit" mode
                document.getElementById('panelTitle').textContent = 'Edit Category';
                document.getElementById('btnCreate').classList.add('d-none');
                document.getElementById('btnUpdate').classList.remove('d-none');
                document.getElementById('btnCancel').classList.remove('d-none');

                // Open panel & scroll into view
                document.getElementById('adminPanel').classList.add('show');
                document.getElementById('adminPanel').scrollIntoView({ behavior: 'smooth', block: 'start' });
                document.getElementById('inputName').focus();

            } catch (err) {
                console.error('editCategory error:', err);
                showToast('Could not load category: ' + err.message, 'error');
            }
        }

        // ══════════════════════════════════════════════════════════
        //  RENDER HELPERS
        // ══════════════════════════════════════════════════════════

        function renderAll() {
            hideSkeleton();
            renderCategoryPills();
            renderPublicView();
            renderAdminTable();
        }

        // Category filter pills in hero
        function renderCategoryPills() {
            const tabs = document.getElementById('categoryTabs');
            tabs.innerHTML = `
                <button class="cat-pill ${activeFilter === 'all' ? 'active' : ''}" data-id="all">
                    All Categories
                </button>`;

            allCategories.forEach(cat => {
                const btn = document.createElement('button');
                btn.className   = `cat-pill ${String(activeFilter) === String(cat.id) ? 'active' : ''}`;
                btn.dataset.id  = cat.id;
                btn.textContent = cat.categoryName;
                tabs.appendChild(btn);
            });

            tabs.querySelectorAll('.cat-pill').forEach(btn => {
                btn.addEventListener('click', () => {
                    tabs.querySelectorAll('.cat-pill').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    activeFilter = btn.dataset.id;
                    renderPublicView();
                });
            });
        }

        // Public accordion FAQ view
        function renderPublicView() {
            const container = document.getElementById('faqSections');
            const list = activeFilter === 'all'
                ? allCategories
                : allCategories.filter(c => String(c.id) === String(activeFilter));

            if (list.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-folder2-open"></i>
                        <p>No categories yet. Use the <strong>Manage Categories</strong> panel to add some.</p>
                    </div>`;
                return;
            }

            container.innerHTML = list.map((cat, idx) => buildSectionHtml(cat, idx)).join('');

            // Bind accordion toggles
            container.querySelectorAll('.faq-q').forEach(q => {
                q.addEventListener('click', () => {
                    const item      = q.closest('.faq-item');
                    const accordion = q.closest('.faq-accordion');
                    const wasOpen   = item.classList.contains('open');
                    accordion.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
                    if (!wasOpen) item.classList.add('open');
                });
            });
        }

        // Build HTML for one category section
        function buildSectionHtml(cat, idx) {
            const thumb = cat.categoryImage
                ? `<img src="${esc(cat.categoryImage)}" class="section-thumb"
                        alt="${esc(cat.categoryName)}"
                        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                   <div class="section-thumb-placeholder" style="display:none">
                       <i class="bi bi-image"></i>
                   </div>`
                : `<div class="section-thumb-placeholder"><i class="bi bi-grid-3x3-gap"></i></div>`;

            // Placeholder FAQ items — replace with real FAQ data from a FaqItem API if you have one
            const placeholderQAs = [
                {
                    q: `What is ${cat.categoryName}?`,
                    a: cat.categoryDescription || `${cat.categoryName} covers key topics and answers common questions in this area.`
                },
                {
                    q: `Who can benefit from ${cat.categoryName}?`,
                    a: 'Businesses of all sizes can benefit. Solutions are tailored to specific needs and scaled accordingly.'
                },
                {
                    q: `How long does ${cat.categoryName} take?`,
                    a: 'Timeline depends on project scope. Most engagements complete within a few weeks to several months.'
                },
                {
                    q: `What does ${cat.categoryName} cost?`,
                    a: 'Pricing depends on requirements and complexity. Contact us for a custom estimate tailored to your project.'
                }
            ];

            const accordionHtml = placeholderQAs.map((qa, i) => `
                <div class="faq-item">
                    <div class="faq-q">
                        <div class="faq-num">${i + 1}</div>
                        <div class="faq-q-text">${esc(qa.q)}</div>
                        <i class="bi bi-chevron-down faq-chevron"></i>
                    </div>
                    <div class="faq-a">
                        <p class="faq-a-text">${esc(qa.a)}</p>
                    </div>
                </div>`).join('');

            return `
            <div class="faq-section-block" id="section-${cat.id}">
                <div class="section-header">
                    ${thumb}
                    <div>
                        <div class="section-category-label">FAQ Category · ${cat.categorySequence ?? idx + 1}</div>
                        <div class="section-title">${esc(cat.categoryName)}</div>
                        <div class="section-desc">${esc(cat.categoryDescription || '')}</div>
                    </div>
                </div>
                <div class="faq-accordion">${accordionHtml}</div>
            </div>`;
        }

        // Admin data table
        function renderAdminTable() {
            const tbody = document.getElementById('adminTableBody');
            if (allCategories.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" style="color:var(--text-muted);text-align:center;padding:1.2rem;">
                            No categories yet.
                        </td>
                    </tr>`;
                return;
            }

            tbody.innerHTML = allCategories.map(cat => `
                <tr>
                    <td style="color:var(--text-muted)">${cat.id}</td>
                    <td class="td-name">${esc(cat.categoryName)}</td>
                    <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                        title="${esc(cat.categoryDescription || '')}">
                        ${esc(cat.categoryDescription || '—')}
                    </td>
                    <td><span class="td-seq">${cat.categorySequence ?? '—'}</span></td>
                    <td><span class="td-badge ${cat.isParent ? 'yes' : ''}">${cat.isParent ? 'Yes' : 'No'}</span></td>
                    <td>${cat.parentSequence ?? '—'}</td>
                    <td>
                        <button class="btn-tbl-edit" onclick="editCategory(${cat.id})" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn-tbl-del"
                                onclick="deleteCategory(${cat.id}, '${escJs(cat.categoryName)}')"
                                title="Delete">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </td>
                </tr>`).join('');
        }

        // ══════════════════════════════════════════════════════════
        //  FORM UTILITIES
        // ══════════════════════════════════════════════════════════

        function buildPayload() {
            const name = document.getElementById('inputName').value.trim();
            if (!name) {
                showToast('Category name is required.', 'error');
                document.getElementById('inputName').focus();
                return null;
            }
            return {
                categoryName:        name,
                categoryDescription: document.getElementById('inputDesc').value.trim(),
                categoryImage:       document.getElementById('inputImage').value.trim(),
                categorySequence:    parseInt(document.getElementById('inputSeq').value)       || 1,
                isParent:            document.getElementById('inputIsParent').value === 'true',
                parentSequence:      parseInt(document.getElementById('inputParentSeq').value) || 0
            };
        }

        function clearForm() {
            ['inputName', 'inputDesc', 'inputImage', 'inputSeq', 'inputParentSeq']
                .forEach(id => document.getElementById(id).value = '');
            document.getElementById('inputIsParent').value = 'true';
        }

        function cancelEdit() {
            clearForm();
            document.getElementById('editId').value = '';
            document.getElementById('panelTitle').textContent = 'Add New Category';
            document.getElementById('btnCreate').classList.remove('d-none');
            document.getElementById('btnUpdate').classList.add('d-none');
            document.getElementById('btnCancel').classList.add('d-none');
        }

        // ══════════════════════════════════════════════════════════
        //  UI UTILITIES
        // ══════════════════════════════════════════════════════════

        function hideSkeleton() {
            const el = document.getElementById('faqSkeleton');
            if (el) el.style.display = 'none';
        }

        function showToast(msg, type = 'success') {
            const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
            const el   = document.createElement('div');
            el.className = `my-toast ${type}`;
            el.innerHTML = `<i class="bi ${icon} ti-${type}"></i><span>${msg}</span>`;
            document.getElementById('toastContainer').appendChild(el);
            setTimeout(() => el.remove(), 3500);
        }

        // Safe HTML escape
        function esc(str) {
            if (str == null) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        // Safe single-quote escape for inline onclick attrs
        function escJs(str) {
            return str ? String(str).replace(/\\/g, '\\\\').replace(/'/g, "\\'") : '';
        }

        // ── Admin panel toggle ─────────────────────────────────────
        document.getElementById('btnToggleAdmin').addEventListener('click', () => {
            const panel = document.getElementById('adminPanel');
            panel.classList.toggle('show');
            if (panel.classList.contains('show')) renderAdminTable();
        });

        // ══════════════════════════════════════════════════════════
        //  INIT — load data on page ready
        // ══════════════════════════════════════════════════════════
        fetchCategories();
    </script>
</body>
</html>
