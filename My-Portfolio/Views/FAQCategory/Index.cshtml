@{
    ViewData["Title"] = "FAQ - Frequently Asked Questions";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
<link href="~/css/FAQCategory.css" rel="stylesheet" />

<section class="faq-hero">
    <div class="container">
        <span class="hero-label"><i class="bi bi-patch-question me-1"></i> Knowledge Base</span>
        <h1>Frequently Asked<br>Questions</h1>
        <p>Find quick answers to common questions about our services, process, pricing, and support.</p>
    </div>
</section>

<main class="container faq-content-area" style="padding-top:2.5rem;">
    <div id="faqSections">
        <p style="color:var(--text-muted);text-align:center;">Loading...</p>
    </div>
</main>

<script>
    const API_BASE = 'https://localhost:7032/api/FaqCategory';

    function esc(str) {
        if (str == null) return '';
        return String(str)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function buildSectionHtml(cat) {
        const imageUrl = cat.categoryImage || 'https://images.unsplash.com/photo-1677442136019-21780ecad995';
        return `
        <div class="faq-card shadow-lg mb-5">
            <div class="row g-0">
                <div class="col-md-5 position-relative">
                    <img src="${imageUrl}" style="width:100%;height:100%;object-fit:cover;" />
                    <div style="position:absolute;top:50%;transform:translateY(-50%);left:30px;color:white;">
                        <h2 style="font-weight:800;">${esc(cat.categoryName)}</h2>
                        <p style="max-width:300px;">${esc(cat.categoryDescription || '')}</p>
                    </div>
                </div>
                <div class="col-md-7 p-4">
                    <h3 class="mb-3 fw-bold">${esc(cat.categoryName)}</h3>
                    <p class="text-muted">${esc(cat.categoryDescription || '')}</p>
                    <a href="/FAQ/Index" class="btn btn-primary mt-2">Read More →</a>
                </div>
            </div>
        </div>`;
    }

    async function fetchCategories() {
        const container = document.getElementById('faqSections');
        try {
            const res = await fetch(API_BASE);
            if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
            const data = await res.json();

            if (!data.length) {
                container.innerHTML = '<div class="text-center text-muted py-5">No categories found.</div>';
                return;
            }
            container.innerHTML = data.map(buildSectionHtml).join('');
        } catch (err) {
            console.error(err);
            container.innerHTML = `
                <div class="text-center text-muted py-5">
                    <i class="bi bi-wifi-off fs-3 d-block mb-2"></i>
                    API connect nahi ho pa raha: <code>${API_BASE}</code>
                </div>`;
        }
    }

    fetchCategories();
</script>